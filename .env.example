# Copy to .env and fill in real values.

# --- LLM providers ---
GROQ_API_KEY=gsk_xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx

# --- Supabase (backend — service_role key, never send to frontend) ---
# From your Supabase project: Settings -> API.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx...

# --- Supabase (frontend — anon/public key, safe in browser) ---
# From your Supabase project: Settings -> API -> anon public key.
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJxxxxx...

# --- RabbitMQ ---
RABBITMQ_URL=amqp://rabbitmq:5672

# --- Backend ---
PORT=4000
INGEST_URL=http://localhost:4000/api/ingest
